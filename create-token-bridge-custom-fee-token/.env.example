# Address of the Rollup contract
ROLLUP_ADDRESS=

# Private key of the account with executor privileges in the UpgradeExecutor admin contract for the chain
# (usually, the deployer of the chain)
ROLLUP_OWNER_PRIVATE_KEY=

# Custom fee token address on the parent chain
CUSTOM_FEE_TOKEN_ADDRESS=

# Orbit chain configuration
ORBIT_CHAIN_ID=
ORBIT_CHAIN_RPC=

# (Optional) Infura RPC endpoint for the parent chain (Arbitrum Sepolia), if not provided, the script might fail with timeout
PARENT_CHAIN_RPC=https://arbitrum-sepolia.infura.io/v3/YOUR_API_KEY


#Custom token configuration
CURRENCY_NAME=
CURRENCY_SYMBOL=
CURRENCY_DECIMAL=

#Chain Configuration
CHAIN_NAME=
## default - 100000000
MIN_L2_BASE_FEE=


#For fetching Token bridge contract
INBOX_ADDRESS=